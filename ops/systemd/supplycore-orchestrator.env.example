# Copy to /etc/default/supplycore-orchestrator and adjust for your host if desired.
APP_ENV=production
APP_TIMEZONE=UTC
SCHEDULER_SUPERVISOR_MODE=python
ORCHESTRATOR_HEALTH_CHECK_INTERVAL_SECONDS=15
ORCHESTRATOR_WORKER_GRACE_SECONDS=45
ORCHESTRATOR_WORKER_START_BACKOFF_SECONDS=5
ORCHESTRATOR_MAX_CONSECUTIVE_HEALTH_FAILURES=3
