DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=supplycore
DB_USERNAME=supplycore
DB_PASSWORD=StrongPasswordHere
DB_SOCKET=
APP_ENV=development

# GitHub integration — log-to-issues worker (optional)
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GITHUB_REPO=maferick/SupplyCore

# InfluxDB time-series analytics (optional)
# INFLUXDB_ENABLED=0
# INFLUXDB_URL=http://127.0.0.1:8086
# INFLUXDB_ORG=my-org
# INFLUXDB_BUCKET=supplycore_rollups
# INFLUXDB_TOKEN=
# INFLUXDB_READ_MODE=disabled
# INFLUXDB_WRITE_ON_ROLLUP=0
